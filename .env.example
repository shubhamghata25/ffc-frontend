# ── FRONTEND ENV VARS ─────────────────────────────────────────────────────────
# Only public values go here. NEVER put secrets in VITE_ variables.
# Anything prefixed VITE_ is compiled into your JS bundle and visible to anyone.

# Your backend URL (no trailing slash)
VITE_API_URL=https://your-backend.onrender.com

# VITE_ADMIN_SECRET has been REMOVED. Admin auth now uses JWT from the server.
